        "Set-ItemProperty -Path 'HKCU:\\Control Panel\\Desktop' -Name 'MenuShowDelay' -Value '0' -Force",
        "if (-not (Test-Path 'HKCU:\\Control Panel\\Desktop\\WindowMetrics')) { New-Item 'HKCU:\\Control Panel\\Desktop\\WindowMetrics' -Force | Out-Null }; Set-ItemProperty -Path 'HKCU:\\Control Panel\\Desktop\\WindowMetrics' -Name 'MinAnimate' -Value '0' -Force"
      ],
      "restart_explorer": false,
      "requer_admin": false,
      "requer_reiniciar": true
    },
    {
      "id": "high_perf_plan",
      "label": "Plano de energia: Alta Performance",
      "descricao": "Ativa o plano de energia 'Alto Desempenho' para máxima velocidade de CPU. Requer admin.",
      "categoria": "performance",
      "detect": "(powercfg /getactivescheme 2>&1) -match '8c5e7fda-e8bf-4a96-9a85-a6e23a8c635c|e9a42b02-d5df-448d-aa00-03f14749eb61'",
      "apply": [
