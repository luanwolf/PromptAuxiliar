{
  "categorias": {
    "taskbar": "Barra de Tarefas",
    "startmenu": "Menu Iniciar",
    "explorer": "Explorador de Arquivos",
    "privacidade": "Privacidade",
    "performance": "Performance",
    "interface": "Interface"
  },
  "tweaks": [
    {
      "id": "taskbar_center",
      "label": "Centralizar ícones da barra de tarefas",
      "descricao": "Centraliza os ícones da barra de tarefas (padrão Windows 11). Para mover à esquerda use 'Ícones à esquerda'.",
      "categoria": "taskbar",
      "detect": "((Get-ItemProperty 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name TaskbarAl -EA 0).TaskbarAl -ne 0)",
      "apply": [
        "Set-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name 'TaskbarAl' -Value 1 -Force"
      ],
      "restart_explorer": true,
      "requer_admin": false,
      "requer_reiniciar": false
    },
    {
      "id": "taskbar_left",
      "label": "Ícones à esquerda (estilo clássico)",
      "descricao": "Move os ícones da barra de tarefas para a esquerda, estilo clássico (Win 10 / Win 11 classic).",
      "categoria": "taskbar",
      "detect": "(Get-ItemProperty 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name TaskbarAl -EA 0).TaskbarAl -eq 0",
      "apply": [
        "Set-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name 'TaskbarAl' -Value 0 -Force"
      ],
      "restart_explorer": true,
      "requer_admin": false,
      "requer_reiniciar": false
    },
    {
      "id": "taskbar_combine_never",
      "label": "Nunca combinar botões da barra de tarefas",
      "descricao": "Mostra cada janela como um botão separado na barra de tarefas, sem agrupamento por aplicativo.",
      "categoria": "taskbar",
      "detect": "(Get-ItemProperty 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name TaskbarGlomLevel -EA 0).TaskbarGlomLevel -eq 2",
      "apply": [
        "Set-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name 'TaskbarGlomLevel' -Value 2 -Force; Set-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name 'MMTaskbarGlomLevel' -Value 2 -Force"
      ],
      "restart_explorer": true,
      "requer_admin": false,
      "requer_reiniciar": false
    },
    {
      "id": "taskbar_search_off",
      "label": "Ocultar caixa de pesquisa",
      "descricao": "Remove a caixa de pesquisa da barra de tarefas (mantém atalho de teclado Win+S).",
      "categoria": "taskbar",
      "detect": "(Get-ItemProperty 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Search' -Name SearchboxTaskbarMode -EA 0).SearchboxTaskbarMode -eq 0",
      "apply": [
        "if (-not (Test-Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Search')) { New-Item 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Search' -Force | Out-Null }; Set-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Search' -Name 'SearchboxTaskbarMode' -Value 0 -Force"
      ],
      "restart_explorer": true,
      "requer_admin": false,
      "requer_reiniciar": false
    },
    {
      "id": "taskbar_widgets_off",
      "label": "Remover botão Widgets",
      "descricao": "Oculta o botão de Widgets (notícias e clima) da barra de tarefas (Win 11).",
      "categoria": "taskbar",
      "detect": "(Get-ItemProperty 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name TaskbarDa -EA 0).TaskbarDa -eq 0",
      "apply": [
        "Set-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name 'TaskbarDa' -Value 0 -Force"
      ],
      "restart_explorer": true,
      "requer_admin": false,
      "requer_reiniciar": false
    },
    {
      "id": "taskbar_taskview_off",
