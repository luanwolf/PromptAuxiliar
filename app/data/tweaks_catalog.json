      "descricao": "Para o serviço SysMain que pré-carrega apps na RAM. Recomendado para quem usa SSD. Requer admin.",
      "categoria": "performance",
      "detect": "(Get-ItemProperty 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\SysMain' -Name Start -EA 0).Start -eq 4",
      "apply": [
        "Set-ItemProperty -Path 'HKLM:\\SYSTEM\\CurrentControlSet\\Services\\SysMain' -Name 'Start' -Value 4 -Force; Stop-Service -Name 'SysMain' -Force -ErrorAction SilentlyContinue"
      ],
      "restart_explorer": false,
      "requer_admin": true,
      "requer_reiniciar": false
    },
    {
      "id": "hibernation_off",
