      "categoria": "taskbar",
      "detect": "(Get-ItemProperty 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name ShowTaskViewButton -EA 0).ShowTaskViewButton -eq 0",
      "apply": [
        "Set-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name 'ShowTaskViewButton' -Value 0 -Force"
      ],
      "restart_explorer": true,
      "requer_admin": false,
      "requer_reiniciar": false
    },
    {
      "id": "taskbar_chat_off",
      "label": "Remover botão Chat (Teams)",
      "descricao": "Oculta o botão de atalho do Microsoft Teams Chat da barra de tarefas (Win 11).",
      "categoria": "taskbar",
      "detect": "(Get-ItemProperty 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name TaskbarMn -EA 0).TaskbarMn -eq 0",
      "apply": [
        "Set-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced' -Name 'TaskbarMn' -Value 0 -Force"
      ],
      "restart_explorer": true,
